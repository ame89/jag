// Gruppe 5: Anschlussnutzer (Erzeuger + Verbraucher + Prosumer,
// zusammengelegt — Idee.md: die PowerElectronicsUnit-Familie nutzt für
// Erzeuger- und Verbraucher-Rolle nahezu identische Attribute, die Rolle
// ergibt sich rein aus der Klasse). ✅ Zweipole: SynchronousMachine,
// AsynchronousMachine, ThermalGeneratingUnit, HydroGeneratingUnit,
// WindGeneratingUnit, SolarGeneratingUnit, GeneratingUnit, FossilFuel,
// PhotoVoltaicUnit, BatteryUnit, ExternalNetworkInjection,
// EquivalentInjection, ReactiveCapabilityCurve (Katalog), CurveData
// (Katalog), EnergyConsumer, ConformLoad, Heatpump, AirConditioningUnit.
// ❌ Anhängsel: LoadResponseCharacteristic.
{
  classes: {
    EnergyConsumer: {
      description: "Allgemeiner Verbraucher (Zweipol, meist Single-Terminal-Senke) — z.B. ein Haushaltsanschluss ohne Erzeugung."
      group: Anschlussnutzer
      terminals: 1
      attributes: [
        {
          key: IdentifiedObject.mRID
          type: string
          required: true
          description: "Eindeutige, global stabile ID des Objekts."
        }
        {
          key: IdentifiedObject.name
          type: string
          required: false
          description: "Menschlich lesbarer Name."
        }
        {
          key: Equipment.EquipmentContainer
          type: "Referenz -> Bay/Feeder/Building"
          required: true
          description: "Zugehöriges Feld/Haus."
        }
        {
          key: Equipment.normallyInService
          type: bool
          required: false
          description: "Normalbetriebszustand."
        }
        {
          key: ConductingEquipment.BaseVoltage
          type: "Referenz -> BaseVoltage"
          required: false
          description: "Spannungsebene."
        }
        {
          key: EnergyConsumer.p
          type: "float (MW)"
          required: false
          description: "Wirkleistungsbezug in MW (bei kW-Eingabe: Umrechnung /1000, siehe Konzept.md)."
        }
        {
          key: EnergyConsumer.q
          type: "float (Mvar)"
          required: false
          description: "Blindleistungsbezug in Mvar."
        }
        {
          key: EnergyConsumer.LoadResponse
          type: "Referenz -> LoadResponseCharacteristic"
          required: false
          description: "Spannungsabhängigkeitsmodell der Last."
        }
      ]
    }
    ConformLoad: {
      description: "Verbraucher, der einer bekannten Lastkurve/-gruppe folgt (Prognose-/Schätzmodell) — strukturell wie EnergyConsumer."
      group: Anschlussnutzer
      terminals: 1
      attributes: [
        {
          key: IdentifiedObject.name
          type: string
          required: false
          description: "Menschlich lesbarer Name."
        }
        {
          key: Equipment.EquipmentContainer
          type: "Referenz -> Bay/Feeder"
          required: true
          description: "Zugehöriges Feld."
        }
        {
          key: EnergyConsumer.p
          type: "float (MW)"
          required: false
          description: "Wirkleistungsbezug in MW."
        }
        {
          key: EnergyConsumer.q
          type: "float (Mvar)"
          required: false
          description: "Blindleistungsbezug in Mvar."
        }
        {
          key: ConformLoad.LoadGroup
          type: "Referenz -> ConformLoadGroup"
          required: false
          description: "Zugehörige Lastgruppe (Prognosemodell)."
        }
      ]
    }
    Heatpump: {
      description: "Wärmepumpe — steuerbarer Verbraucher (§14a EnWG, steuVA), strukturell Teil der PowerElectronicsUnit-Familie."
      group: Anschlussnutzer
      terminals: 0
      attributes: [
        {
          key: IdentifiedObject.name
          type: string
          required: false
          description: "Menschlich lesbarer Name."
        }
        {
          key: Equipment.EquipmentContainer
          type: "Referenz -> Building"
          required: false
          description: "Zugehöriges Haus (falls direkt referenziert)."
        }
        {
          key: Equipment.normallyInService
          type: bool
          required: false
          description: "Normalbetriebszustand."
        }
        {
          key: PowerElectronicsUnit.PowerElectronicsConnection
          type: "Referenz -> PowerElectronicsConnection"
          required: true
          description: "Zugehöriger Netzanschlusspunkt (Steuerbox-Anschluss)."
        }
        {
          key: PowerElectronicsUnit.marketParticipantLocationIdentifier
          type: string
          required: false
          description: "MaLo-artige Markt-Lokations-ID."
        }
        {
          key: PowerElectronicsUnit.maxP
          type: "float (MW)"
          required: false
          description: "Maximale Wirkleistungsaufnahme in MW."
        }
        {
          key: PowerElectronicsUnit.minP
          type: "float (MW)"
          required: false
          description: "Minimale Wirkleistungsaufnahme in MW."
        }
        {
          key: PowerElectronicsUnit.technicalResourceIdentifier
          type: string
          required: false
          description: "Technische Anlagen-ID."
        }
      ]
    }
    AirConditioningUnit: {
      description: "Klimaanlage — steuerbarer Verbraucher (§14a EnWG, steuVA), strukturell Teil der PowerElectronicsUnit-Familie."
      group: Anschlussnutzer
