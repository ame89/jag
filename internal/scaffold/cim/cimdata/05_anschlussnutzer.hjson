    GeneratingUnit: {
      description: "Erzeugungseinheit — Metadaten-/Gruppierungsobjekt über eine oder mehrere rotierende Maschinen (kein eigener Zweipol; die Zuordnung erfolgt als ✅ in Idee.md, da faktisch Bestandteil des Erzeuger-Zweipols)."
      group: Anschlussnutzer
      terminals: 0
      attributes: [
        {
          key: IdentifiedObject.name
          type: string
          required: false
          description: "Menschlich lesbarer Name."
        }
        {
          key: GeneratingUnit.maxOperatingP
          type: "float (MW)"
          required: false
          description: "Maximale Betriebsleistung in MW."
        }
        {
          key: GeneratingUnit.minOperatingP
          type: "float (MW)"
          required: false
          description: "Minimale Betriebsleistung in MW."
        }
        {
          key: GeneratingUnit.ratedNetMaxP
          type: "float (MW)"
          required: false
          description: "Nenn-Nettohöchstleistung in MW."
        }
        {
          key: GeneratingUnit.genControlSource
          type: "enum"
          required: false
          description: "Art der Leistungsregelung (z.B. unregulated/offAGC/onAGC)."
        }
      ]
    }
