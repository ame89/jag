        }
        {
          key: PowerElectronicsUnit.marketParticipantLocationIdentifier
          type: string
          required: false
          description: "MaLo-artige Markt-Lokations-ID."
        }
        {
          key: PowerElectronicsUnit.maxP
          type: "float (MW)"
          required: true
          description: "Maximale Einspeiseleistung (Peak) in MW."
        }
        {
          key: PowerElectronicsUnit.minP
          type: "float (MW)"
          required: false
          description: "Minimale Einspeiseleistung in MW."
        }
        {
          key: PowerElectronicsUnit.technicalResourceIdentifier
          type: string
          required: false
          description: "Technische Anlagen-ID."
        }
      ]
    }
    BatteryUnit: {
      description: "Batteriespeicher (Prosumer-Rolle: Einspeisung UND Bezug möglich) — strukturell Teil der PowerElectronicsUnit-Familie."
      group: Anschlussnutzer
      terminals: 0
      attributes: [
        {
          key: IdentifiedObject.name
          type: string
          required: false
          description: "Menschlich lesbarer Name."
        }
        {
          key: Equipment.EquipmentContainer
          type: "Referenz -> Building/Bay"
          required: false
          description: "Zugehöriges Haus/Feld."
        }
        {
          key: PowerElectronicsUnit.PowerElectronicsConnection
          type: "Referenz -> PowerElectronicsConnection"
          required: true
          description: "Zugehöriger Netzanschlusspunkt."
        }
        {
          key: PowerElectronicsUnit.maxP
          type: "float (MW)"
          required: true
          description: "Maximale Lade-/Entladeleistung in MW."
        }
        {
          key: PowerElectronicsUnit.minP
          type: "float (MW)"
          required: false
          description: "Minimale Leistung in MW."
        }
        {
          key: BatteryUnit.ratedE
          type: "float (MWh)"
          required: false
          description: "Nennkapazität in MWh."
        }
        {
          key: BatteryUnit.storedE
          type: "float (MWh)"
          required: false
          description: "Aktuell gespeicherte Energie in MWh (Momentaufnahme, keine Live-Telemetrie bei JAG)."
        }
      ]
    }
    SynchronousMachine: {
      description: "Synchronmaschine (Generator oder Motor, Zweipol) — z.B. klassischer Kraftwerksgenerator."
      group: Anschlussnutzer
      terminals: 1
      attributes: [
        {
          key: IdentifiedObject.name
          type: string
          required: false
          description: "Menschlich lesbarer Name."
        }
        {
          key: Equipment.EquipmentContainer
          type: "Referenz -> Bay"
          required: true
          description: "Zugehöriges Feld."
        }
        {
          key: RotatingMachine.GeneratingUnit
          type: "Referenz -> GeneratingUnit"
          required: false
          description: "Zugehörige Erzeugungseinheit."
        }
        {
          key: RotatingMachine.p
          type: "float (MW)"
          required: false
          description: "Wirkleistung in MW."
        }
        {
          key: RotatingMachine.q
          type: "float (Mvar)"
          required: false
          description: "Blindleistung in Mvar."
        }
        {
          key: RotatingMachine.ratedS
          type: "float (MVA)"
          required: false
          description: "Nennscheinleistung in MVA."
        }
        {
          key: SynchronousMachine.type
          type: "enum (generator/motor/condenser)"
          required: false
          description: "Betriebsart."
        }
      ]
