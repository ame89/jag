    ExternalNetworkInjection: {
      description: "Modellrand-Einspeisung: repräsentiert ein nicht im Detail modelliertes vorgelagertes Netz (z.B. Übertragungsnetz-Anschlusspunkt)."
      group: Anschlussnutzer
      terminals: 1
      attributes: [
        {
          key: IdentifiedObject.name
          type: string
          required: false
          description: "Menschlich lesbarer Name."
        }
        {
          key: Equipment.EquipmentContainer
          type: "Referenz -> Bay"
          required: true
          description: "Zugehöriges Feld (i.d.R. das Einspeisefeld/Incoming-Feeder)."
        }
        {
          key: ExternalNetworkInjection.p
          type: "float (MW)"
          required: false
          description: "Aktuelle/angenommene Wirkleistungseinspeisung in MW."
        }
        {
          key: ExternalNetworkInjection.q
          type: "float (Mvar)"
          required: false
          description: "Aktuelle/angenommene Blindleistungseinspeisung in Mvar."
        }
        {
          key: ExternalNetworkInjection.maxP
          type: "float (MW)"
          required: false
          description: "Maximal mögliche Einspeiseleistung in MW."
        }
        {
          key: ExternalNetworkInjection.minP
          type: "float (MW)"
          required: false
          description: "Minimal mögliche Einspeiseleistung in MW."
        }
      ]
    }
    EquivalentInjection: {
      description: "Vereinfachte Ersatzeinspeisung/-last am Modellrand (Bus-Branch-Vereinfachung). Bekannte Ausnahme: wird bei JAG bewusst NICHT auf Vollständigkeit geprüft (nicht geflaggt), siehe Konzept.md."
      group: Anschlussnutzer
      terminals: 1
      attributes: [
        {
          key: IdentifiedObject.name
          type: string
          required: false
          description: "Menschlich lesbarer Name."
        }
        {
          key: Equipment.EquipmentContainer
          type: "Referenz -> Bay"
          required: false
          description: "Zugehöriges Feld."
        }
        {
          key: EquivalentInjection.p
          type: "float (MW)"
          required: false
          description: "Wirkleistung in MW."
        }
        {
          key: EquivalentInjection.q
          type: "float (Mvar)"
          required: false
          description: "Blindleistung in Mvar."
        }
        {
          key: EquivalentInjection.regulationCapability
          type: bool
          required: false
          description: "Ob eine Spannungsregelung möglich ist."
        }
      ]
    }
    ReactiveCapabilityCurve: {
      description: "Katalogeintrag: Blindleistungs-Fähigkeitskurve eines Generators (P/Q-Diagramm), potenziell von mehreren Maschinen gleichen Typs geteilt (Katalog)."
      group: Anschlussnutzer
      terminals: 0
      attributes: [
        {
          key: IdentifiedObject.name
          type: string
          required: true
          description: "Bezeichnung der Kurve."
        }
      ]
    }
    CurveData: {
      description: "Ein Stützpunkt einer Curve (z.B. ReactiveCapabilityCurve) — Katalog, nicht eigentümerspezifisch."
      group: Anschlussnutzer
      terminals: 0
      attributes: [
        {
          key: CurveData.Curve
          type: "Referenz -> ReactiveCapabilityCurve"
          required: true
          description: "Zugehörige Kurve."
        }
        {
          key: CurveData.xvalue
          type: float
          required: true
          description: "X-Achsenwert des Stützpunkts (z.B. Wirkleistung)."
        }
        {
          key: CurveData.y1value
          type: float
          required: true
          description: "Y-Achsenwert des Stützpunkts (z.B. min. Blindleistung)."
        }
        {
          key: CurveData.y2value
          type: float
          required: false
          description: "Zweiter Y-Achsenwert (z.B. max. Blindleistung)."
        }
      ]
    }
    LoadResponseCharacteristic: {
      description: "Spannungsabhängigkeitsmodell einer Last (ZIP-Modell) — Anhängsel eines EnergyConsumer/ConformLoad, kein eigenes Betriebsmittel."
      group: Anschlussnutzer
      terminals: 0
      attributes: [
        {
          key: IdentifiedObject.name
          type: string
          required: false
          description: "Menschlich lesbarer Name."
        }
        {
          key: LoadResponseCharacteristic.exponentModel
          type: bool
          required: false
          description: "Ob ein Exponentialmodell (statt ZIP-Koeffizienten) verwendet wird."
        }
        {
          key: LoadResponseCharacteristic.pConstantPower
          type: float
          required: false
          description: "Anteil konstanter Wirkleistung (0..1)."
        }
        {
          key: LoadResponseCharacteristic.pConstantCurrent
          type: float
          required: false
          description: "Anteil konstanten Stroms (0..1)."
        }
        {
          key: LoadResponseCharacteristic.pConstantImpedance
          type: float
          required: false
          description: "Anteil konstanter Impedanz (0..1)."
        }
      ]
    }
  }
}
