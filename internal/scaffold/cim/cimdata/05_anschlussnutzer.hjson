        }
        {
          key: PowerElectronicsUnit.minP
          type: "float (MW)"
          required: false
          description: "Minimale Wirkleistungsaufnahme in MW."
        }
      ]
    }
    PhotoVoltaicUnit: {
      description: "PV-Anlage (Erzeuger-Rolle) — strukturell Teil der PowerElectronicsUnit-Familie."
      group: Anschlussnutzer
      terminals: 0
      attributes: [
        {
          key: IdentifiedObject.name
          type: string
