          description: "Zugehöriges Wicklungsende."
        }
        {
          key: TapChanger.lowStep
          type: int
          required: true
          description: "Niedrigste Stufennummer."
        }
        {
          key: TapChanger.highStep
          type: int
          required: true
          description: "Höchste Stufennummer."
        }
        {
          key: PhaseTapChangerNonLinear.voltageStepIncrement
          type: float
          required: true
          description: "Spannungsänderung pro Stufe in %."
        }
        {
          key: PhaseTapChangerAsymmetrical.windingConnectionAngle
          type: float
          required: true
          description: "Wicklungs-Anschlusswinkel in Grad."
        }
      ]
    }
    PhaseTapChangerSymmetrical: {
      description: "Stufensteller mit symmetrischer Phasenregelung (reine Phasendrehung, keine Spannungsänderung am Nennpunkt) — Anhängsel eines PowerTransformerEnd."
      group: Transformatoren
      terminals: 0
      attributes: [
        {
          key: TapChanger.TransformerEnd
          type: "Referenz -> PowerTransformerEnd"
          required: true
          description: "Zugehöriges Wicklungsende."
        }
        {
          key: TapChanger.lowStep
          type: int
          required: true
          description: "Niedrigste Stufennummer."
        }
        {
          key: TapChanger.highStep
          type: int
          required: true
          description: "Höchste Stufennummer."
        }
        {
          key: PhaseTapChangerNonLinear.voltageStepIncrement
          type: float
          required: true
          description: "Spannungsänderung pro Stufe in %."
        }
      ]
    }
    PhaseTapChangerTabular: {
      description: "Stufensteller mit tabellarisch definierten Stufenwerten (statt Formel) — Anhängsel eines PowerTransformerEnd."
      group: Transformatoren
      terminals: 0
      attributes: [
        {
          key: TapChanger.TransformerEnd
          type: "Referenz -> PowerTransformerEnd"
          required: true
          description: "Zugehöriges Wicklungsende."
        }
        {
          key: TapChanger.lowStep
          type: int
          required: true
          description: "Niedrigste Stufennummer."
        }
        {
          key: TapChanger.highStep
          type: int
          required: true
          description: "Höchste Stufennummer."
        }
        {
          key: PhaseTapChangerTabular.PhaseTapChangerTable
          type: "Referenz -> PhaseTapChangerTable"
          required: true
          description: "Verweis auf die Stufentabelle (Katalog)."
        }
      ]
    }
    RatioTapChangerTable: {
      description: "Katalogeintrag: tabellarische Übersetzungsverhältnis-Stufenwerte, potenziell von mehreren RatioTapChangern gleichen Trafotyps geteilt (Katalog)."
      group: Transformatoren
      terminals: 0
      attributes: [
        {
          key: IdentifiedObject.name
          type: string
          required: true
          description: "Bezeichnung der Stufentabelle."
        }
      ]
    }
    RatioTapChangerTablePoint: {
      description: "Eine Zeile einer RatioTapChangerTable (Katalog, nicht eigentümerspezifisch)."
      group: Transformatoren
      terminals: 0
      attributes: [
        {
          key: TapChangerTablePoint.TapChangerTable
          type: "Referenz -> RatioTapChangerTable"
          required: true
          description: "Zugehörige Stufentabelle."
        }
        {
          key: TapChangerTablePoint.step
          type: int
          required: true
          description: "Stufennummer dieser Zeile."
        }
        {
          key: TapChangerTablePoint.ratio
          type: float
          required: true
          description: "Übersetzungsverhältnis an dieser Stufe."
        }
      ]
    }
    PhaseTapChangerTable: {
      description: "Katalogeintrag: tabellarische Phasenregel-Stufenwerte, potenziell von mehreren PhaseTapChangern gleichen Trafotyps geteilt (Katalog)."
      group: Transformatoren
      terminals: 0
      attributes: [
        {
          key: IdentifiedObject.name
          type: string
          required: true
          description: "Bezeichnung der Stufentabelle."
        }
      ]
    }
    PhaseTapChangerTablePoint: {
      description: "Eine Zeile einer PhaseTapChangerTable (Katalog, nicht eigentümerspezifisch)."
      group: Transformatoren
      terminals: 0
      attributes: [
        {
          key: TapChangerTablePoint.TapChangerTable
          type: "Referenz -> PhaseTapChangerTable"
          required: true
          description: "Zugehörige Stufentabelle."
        }
        {
          key: TapChangerTablePoint.step
          type: int
          required: true
          description: "Stufennummer dieser Zeile."
        }
        {
          key: TapChangerTablePoint.ratio
          type: float
          required: true
          description: "Übersetzungsverhältnis an dieser Stufe."
        }
        {
          key: PhaseTapChangerTablePoint.angle
          type: float
          required: true
          description: "Phasenverschiebung an dieser Stufe, in Grad."
